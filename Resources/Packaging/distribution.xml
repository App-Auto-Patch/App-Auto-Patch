<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>App Auto-Patch</title>
    <background file="AAPLogo.png" alignment="bottomleft" scaling="none" mime-type="image/png"/>
    <background-darkAqua file="AAPLogo.png" alignment="bottomleft" scaling="none" mime-type="image/png"/>
    <welcome file="welcome.txt" mime-type="text/plain"/>
    <readme file="readme.txt" mime-type="text/plain"/>
    <options customize="never" require-scripts="false" rootVolumeOnly="true"/>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>
    <choices-outline>
        <line choice="default">
            <line choice="xyz.techitout.appAutoPatch.installer"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="xyz.techitout.appAutoPatch.installer" visible="false">
        <pkg-ref id="xyz.techitout.appAutoPatch.installer"/>
    </choice>
    <pkg-ref id="xyz.techitout.appAutoPatch.installer" version="0" onConclusion="none">AppAutoPatchComponent.pkg</pkg-ref>
</installer-gui-script>
